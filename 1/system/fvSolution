FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
	T
	{
        solver          smoothSolver;
        tolerance       1e-06;
        relTol          0;
		smoother        GaussSeidel;
	}
}

PIMPLE		//  could have also been PISO 
{
    nCorrectors     2;
    nNonOrthogonalCorrectors 0;
    pRefCell        0;
    pRefValue       0;
}


