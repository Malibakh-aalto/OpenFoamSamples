FoamFile
{
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (6.5 0 0);

boundaryField
{
    inlet
    {
        type            freestreamVelocity;
		freestreamValue	$internalField;
    }

    outlet
    {
        type            zeroGradient;
    }

    plate
    {
        type            noSlip;
    }

    symmTop
    {
        type            symmetryPlane;
    }
    symmBottom
    {
        type            symmetryPlane;
    }
	

}

