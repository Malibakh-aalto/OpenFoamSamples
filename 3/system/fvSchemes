FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes								// this is used for discretization time scheme https://doc.openfoam.com/2312/tools/processing/numerics/schemes/time/
{
    default         steadyState;		// previously we had used Euler or backward 
}

gradSchemes
{
    default         Gauss linear;
}

divSchemes
{
    default         none;
    div(phi,U)      bounded Gauss linearUpwind grad(U);
	div(phi,T)		bounded Gauss linearUpwind grad(T);  // div(phi,T)		Gauss upwind;		// changed this one and we fixed the issue previously it was linear
    div(phi,nuTilda) bounded Gauss linearUpwind grad(nuTilda);
    div((nuEff*dev2(T(grad(U))))) Gauss linear;
}

laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}

wallDist
{
    method meshWave;
}


